{
  "version": 2,
  "crons": [
    {
      "path": "/api/tradingBot",
      "schedule": "*/15 13-20 * * 1-5"
    },
    {
      "path": "/api/cron/dailySignalRefresh",
      "schedule": "15 13 * * 1-5"
    },
    {
  "path": "/api/fetchCongressTrades",
  "schedule": "0 12 * * 1-5"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
